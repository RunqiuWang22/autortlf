# =============================================================================
# AutoRTLF .gitignore
# =============================================================================
# Purpose: Exclude generated files and sensitive data from version control
# Version: 1.0.0
# Created: 2026-01-20
# Author: AutoRTLF Development Team
# =============================================================================

# R specific
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj
.Renviron

# Output directories (keep structure, exclude generated files)
outdata/*
!outdata/.gitkeep
outgraph/*
!outgraph/.gitkeep
!outgraph/X99-ia01/
!outgraph/X99-ia01/*.png
!outgraph/X99-ia01/*.pdf
!outgraph/X99-ia01/*.jpg
!outgraph/X99-ia01/*.jpeg
outlist/*
!outlist/.gitkeep
outlog/*
!outlog/.gitkeep
outtable/*
!outtable/.gitkeep
!outtable/X99-ia01/
!outtable/X99-ia01/*.rtf
!outtable/X99-ia01/combined/
!outtable/X99-ia01/combined/*.rtf

# Temporary files
*.tmp
Rplots.pdf
*.swp
*.swo
*~

# Log files (exclude all logs)
*.log

# IDE files
.vscode/
.idea/
*.sublime-*

# System files
.DS_Store
Thumbs.db
desktop.ini

# Data files (exclude sensitive data)
*.rda
*.csv
*.xlsx
*.sas7bdat
*.sas7bcat

# Keep sample data files
!dataadam/*.rda
!datasdtm/*.rda
!dataadam/
!datasdtm/

# Docker files (exclude build artifacts)
.dockerignore
docker-compose.override.yml
*.tar.gz

# Keep essential Docker files
!Dockerfile
!docker-compose.yml
!docker_validate.R
!install_packages.R

# Documentation (keep source, exclude generated)
*.pdf
*.docx
!documents/*.md

# Backup files
*.bak
*.backup
*~

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows specific
*.lnk
