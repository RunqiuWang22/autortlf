{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autortlf.com/schemas/baseline0char.schema.json",
  "title": "Baseline Characteristics Table Configuration Schema",
  "description": "JSON Schema for baseline demographics and characteristics table configuration",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["Table"],
      "description": "Type of TLF output"
    },
    "rfunction": {
      "type": "string",
      "const": "baseline0char",
      "description": "R function name to execute this table"
    },
    "table_id": {
      "type": "string",
      "description": "Table identifier (e.g., Table 12.1.1.x)",
      "pattern": "^Table\\s+[0-9]+\\.[0-9]+\\.[0-9]+\\.[x0-9]+$"
    },
    "rename_output": {
      "type": "string",
      "description": "Output file name without extension",
      "pattern": "^[a-zA-Z0-9_]+$"
    },
    "title": {
      "type": "string",
      "description": "Main title of the table"
    },
    "subtitle": {
      "type": "string",
      "description": "Subtitle for population and subgroups (supports GLOBAL references)"
    },
    "population_from": {
      "type": "string",
      "description": "Dataset name to use for analysis",
      "enum": ["ADSL", "ADAE", "ADLB", "ADVS", "ADTTE"]
    },
    "population_filter": {
      "type": "string",
      "description": "R expression for population filtering (supports GLOBAL references)"
    },
    "treatment_var": {
      "type": "string",
      "description": "Treatment variable name (supports GLOBAL references)"
    },
    "treatment_code": {
      "type": "string",
      "description": "Treatment code variable name (supports GLOBAL references)"
    },
    "display_options": {
      "type": "object",
      "description": "Display configuration options",
      "properties": {
        "display_n": {
          "type": "boolean",
          "description": "Whether to display N count",
          "default": false
        },
        "display_mean": {
          "type": "boolean",
          "description": "Whether to display mean for continuous variables",
          "default": true
        },
        "display_median": {
          "type": "boolean",
          "description": "Whether to display median for continuous variables",
          "default": true
        },
        "display_range": {
          "type": "boolean",
          "description": "Whether to display min-max range for continuous variables",
          "default": true
        },
        "display_IQR": {
          "type": "boolean",
          "description": "Whether to display interquartile range for continuous variables",
          "default": true
        },
        "display_total_column": {
          "oneOf": [
            {"type": "boolean"},
            {"type": "string", "pattern": "^GLOBAL\\."}
          ],
          "description": "Whether to show overall/total column (supports GLOBAL references)"
        },
        "display_only_total_column": {
          "type": "boolean",
          "description": "Whether to display only the total column (no treatment groups)",
          "default": false
        },
        "create_output_dataset": {
          "oneOf": [
            {"type": "boolean"},
            {"type": "string", "pattern": "^GLOBAL\\."}
          ],
          "description": "Whether to create and save interim dataset (supports GLOBAL references)"
        }
      },
      "additionalProperties": false
    },
    "output_format": {
      "type": "object",
      "description": "Output format configuration",
      "properties": {
        "output_data_format": {
          "oneOf": [
            {"type": "string", "enum": ["rds", "csv"]},
            {"type": "string", "pattern": "^GLOBAL\\."}
          ],
          "description": "Format for output data files (supports GLOBAL references)"
        },
        "output_tlf_format": {
          "oneOf": [
            {"type": "string", "enum": ["rtf", "pdf", "docx", "html"]},
            {"type": "string", "pattern": "^GLOBAL\\."}
          ],
          "description": "Format for TLF output files (supports GLOBAL references)"
        }
      },
      "additionalProperties": false
    },
    "decimals": {
      "type": "object",
      "description": "Decimal place configuration",
      "properties": {
        "continuous": {
          "oneOf": [
            {"type": "integer", "minimum": 0, "maximum": 10},
            {"type": "string", "pattern": "^GLOBAL\\."}
          ],
          "description": "Decimal places for continuous variables (supports GLOBAL references)"
        },
        "percent": {
          "oneOf": [
            {"type": "integer", "minimum": 0, "maximum": 10},
            {"type": "string", "pattern": "^GLOBAL\\."}
          ],
          "description": "Decimal places for percentages (supports GLOBAL references)"
        }
      },
      "additionalProperties": false
    },
    "footnotes": {
      "type": "object",
      "description": "Footnote configuration",
      "properties": {
        "standard": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "string"},
              {"type": "string", "pattern": "^GLOBAL\\."}
            ]
          },
          "description": "Standard footnotes (supports GLOBAL references)"
        },
        "study": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Study-specific footnotes"
        },
        "data_cutoff": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "string"},
              {"type": "string", "pattern": "^GLOBAL\\."}
            ]
          },
          "description": "Data cutoff footnotes (supports GLOBAL references)"
        }
      },
      "additionalProperties": false
    },
    "data_source_text": {
      "type": "string",
      "description": "Data source text (supports GLOBAL references)"
    },
    "variables": {
      "type": "array",
      "description": "List of variables to include in the baseline table",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name for the variable"
          },
          "source_var": {
            "type": "string",
            "description": "Source variable name in the dataset"
          },
          "type": {
            "type": "string",
            "enum": ["continuous", "categorical"],
            "description": "Variable type for statistical analysis"
          },
          "levels": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Predefined levels for categorical variables"
          },
          "label_overrides": {
            "type": "object",
            "patternProperties": {
              ".*": {"type": "string"}
            },
            "description": "Custom labels for categorical variable levels"
          }
        },
        "required": ["name", "source_var", "type"],
        "additionalProperties": false,
        "if": {
          "properties": {"type": {"const": "categorical"}}
        },
        "then": {
          "properties": {
            "levels": {"type": "array"},
            "label_overrides": {"type": "object"}
          }
        }
      },
      "minItems": 1
    }
  },
  "required": [
    "type",
    "rfunction", 
    "table_id",
    "rename_output",
    "title",
    "population_from",
    "variables"
  ],
  "additionalProperties": false
}
